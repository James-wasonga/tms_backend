# Copy to .env and fill in your values
PORT=8085
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/tmsdb?retryWrites=true&w=majority
JWT_SECRET=your_long_random_secret_key_here
NODE_ENV=development

# Optional - only needed for email/forgot-password feature
GOOGLE_EMAIL=youremail@gmail.com
GOOGLE_PASSWORD=your_gmail_app_password
CLIENT_URL=http://localhost:3002
